# Copy this to .env and fill in your API key
# (or export these as shell environment variables)

# --- OpenAI (default) ---
OPENAI_API_KEY=sk-...

# --- Anthropic (optional, use with --use-anthropic flag) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Set to "1" to use Anthropic by default ---
# USE_ANTHROPIC=0
